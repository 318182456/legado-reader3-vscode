{
  "name": "legado-reader3-vscode",
  "displayName": "阅读APP(服务器版)",
  "description": "配合阅读APP(服务器版)用来学习或摸鱼的小说阅读插件。",
  "keywords": [
    "legado",
    "阅读",
    "阅读3.0",
    "阅读APP",
    "小说",
    "摸鱼",
    "学习"
  ],
  "publisher": "318182456",
  "license": "GPL-3.0",
  "version": "1.4.7",
  "icon": "public/ic_launcher.png",
  "qna": "https://github.com/318182456/legado-reader3-vscode/issues",
  "bugs": {
    "url": "https://github.com/318182456/legado-reader3-vscode/issues",
    "email": "318182456@qq.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/318182456/legado-reader3-vscode.git"
  },
  "engines": {
    "vscode": "^1.25.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:legado-reader3-vscode.openLegado"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "legado-reader3-vscode.openLegado",
        "title": "打开阅读APP书架",
        "category": "阅读APP Legado"
      }
    ],
    "configuration": {
      "title": "阅读APP插件",
      "type": "object",
      "properties": {
        "legado-reader3-vscode.panelTitle": {
          "type": "string",
          "default": "阅读",
          "description": "Tab页标题"
        },
        "legado-reader3-vscode.webServeUrl": {
          "type": "string",
          "default": "http://127.0.0.1:1122",
          "description": "阅读APP的WEB服务访问地址"
        },
        "legado-reader3-vscode.enableBottomPanel": {
          "type": "boolean",
          "default": true,
          "description": "是否启用底部阅读独立面板"
        },
        "legado-reader3-vscode.bottomPanelTitle": {
          "type": "string",
          "default": "摸鱼输出",
          "description": "底部阅读面板的自定义标签名称"
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "legado-panel",
          "title": "阅读",
          "icon": "public/ic_launcher.png"
        }
      ]
    },
    "views": {
      "legado-panel": [
        {
          "type": "webview",
          "id": "legado-reader3-vscode.bottomView",
          "name": "阅读界面"
        }
      ]
    }
  },
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "web:build": "npm run build --prefix web",
    "web:dev": "npm run dev --prefix web",
    "web:watch": "npm run watch --prefix web",
    "build": "npm run web:build && vsce package",
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "watch:all": "concurrently \"npm run web:watch\" \"npm run watch\"",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.25.0",
    "@typescript-eslint/eslint-plugin": "^5.59.1",
    "@typescript-eslint/parser": "^5.59.1",
    "@vscode/test-electron": "^2.3.0",
    "concurrently": "^8.0.1",
    "eslint": "^8.39.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "prettier": "^3.6.2",
    "ts-loader": "^9.4.2",
    "typescript": "^5.0.4",
    "vsce": "^2.15.0",
    "webpack": "^5.81.0",
    "webpack-cli": "^5.0.2"
  },
  "volta": {
    "node": "16.20.2",
    "npm": "8.19.4"
  }
}
